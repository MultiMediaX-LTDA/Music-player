<?xml version="1.0" encoding="utf-8"?>
<<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="JAMMER LIBRARY"
        android:textColor="#FF00FF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#000000" />

    <SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:queryHint="Search..."
        android:background="#333333" />

    <!-- INVISÍVEL — só para o código não quebrar -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupReleaseType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvScanStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scanning..."
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#000000" />

    <Button
        android:id="@+id/btnAddFolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ ADD FOLDER"
        android:textColor="#FFFFFF"
        android:background="#444444" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLibrary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FF0000" />

    <Button
        android:id="@+id/fabRescan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RESCAN"
        android:textColor="#FFFFFF"
        android:background="#666666" />

</LinearLayout>
