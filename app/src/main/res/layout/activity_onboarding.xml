<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo / Título -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/album_placeholder_vinyl"
            android:layout_marginTop="32dp"
            android:contentDescription="Jammer Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jammer"
            android:textSize="36sp"
            android:textColor="#D4A574"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seu player de música. Sem rastreamento. Sem frescura."
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Card de Permissões -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2A2A2A"
            android:padding="16dp"
            android:layout_marginTop="32dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐 Permissões Necessárias"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O Jammer precisa acessar seus arquivos de música. Nada mais."
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvPermissionInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❌ Áudio | ❌ Storage"
                android:textSize="14sp"
                android:textColor="#FF6B6B"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnGrantPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conceder Permissões"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D4A574"
                android:textColor="#1A1A1A" />
        </LinearLayout>

        <!-- Card de Modo de Scan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2A2A2A"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁 Modo de Sincronização"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgScanMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:checkedButton="@id/rbAuto">

                <RadioButton
                    android:id="@+id/rbAuto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Automático"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escaneia todo o celular automaticamente quando detecta música nova."
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginStart="32dp"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rbManual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manual"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Você escolhe as pastas e sincroniza quando quiser."
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:layout_marginStart="32dp" />
            </RadioGroup>

            <Button
                android:id="@+id/btnPickFolders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Escolher Pastas (SAF)"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                android:backgroundTint="#4A90D9"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Status e botão final -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure as permissões para continuar"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="24dp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Iniciar Jammer"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:enabled="false"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
